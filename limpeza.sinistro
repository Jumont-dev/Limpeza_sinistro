        "<a href=\"https://colab.research.google.com/github/Jumont-dev/Limpeza_sinistro/blob/main/limpeza.sinistro\" target=\"_parent\"><img src=\"https://colab.research.google.com/assets/colab-badge.svg\" alt=\"Open In Colab\"/></a>"

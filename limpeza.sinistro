      "source": [
        "missing_values_reloaded = df.isnull().sum()\n",
        "missing_percentage_reloaded = (df.isnull().sum() / len(df)) * 100\n",
        "\n",
        "missing_info_reloaded = pd.DataFrame({\n",
        "    'Missing Values': missing_values_reloaded,\n",
        "    'Percentage': missing_percentage_reloaded\n",
        "})\n",
        "\n",
        "missing_info_reloaded = missing_info_reloaded[missing_info_reloaded['Missing Values'] > 0].sort_values(by='Missing Values', ascending=False)\n",
        "\n",
        "if not missing_info_reloaded.empty:\n",
        "    print(\"Colunas com Valores Ausentes (após recarregamento e limpeza inicial):\")\n",
        "    display(missing_info_reloaded)\n",
        "else:\n",
        "    print(\"Não há valores ausentes restantes no DataFrame.\")"
      ],
      "execution_count": 8,

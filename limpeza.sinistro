        "\n",
        "# Salvar o DataFrame como um arquivo Excel\n",
        "df_cleaned_csv.to_excel('SINISTRO_limpo.xlsx', index=False)\n",
        "print(\"DataFrame salvo como 'SINISTRO_limpo.xlsx' com sucesso!\")\n",
        "\n",
        "# Baixar o arquivo Excel\n",
        "files.download('SINISTRO_limpo.xlsx')"

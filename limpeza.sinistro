        "id": "8df71148",
        "outputId": "e138e6e5-5c57-41d3-d243-160a654ad60b"
      },
      "source": [
        "qtd_cols = [col for col in df.columns if col.startswith('qtd_')]\n",
        "\n",
        "filled_count = 0\n",
        "for col in qtd_cols:\n",
        "    if df[col].isnull().any():\n",
        "        initial_nulls = df[col].isnull().sum()\n",
        "        df[col] = df[col].fillna(0)\n",
        "        filled_count += initial_nulls\n",
        "        print(f\"Preenchidos {initial_nulls} valores NaN na coluna '{col}' com 0.\")\n",
        "\n",
        "if filled_count == 0:\n",
        "    print(\"Não há valores NaN nas colunas 'qtd_' para preencher com 0.\")\n",
        "else:\n",
        "    print(f\"Total de {filled_count} valores NaN preenchidos com 0 nas colunas 'qtd_'.\")\n"
      ],
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Preenchidos 37667 valores NaN na coluna 'qtd_pedestre' com 0.\n",
            "Preenchidos 39148 valores NaN na coluna 'qtd_bicicleta' com 0.\n",
            "Preenchidos 24439 valores NaN na coluna 'qtd_motocicleta' com 0.\n",
            "Preenchidos 24596 valores NaN na coluna 'qtd_automovel' com 0.\n",
            "Preenchidos 38541 valores NaN na coluna 'qtd_onibus' com 0.\n",
            "Preenchidos 38209 valores NaN na coluna 'qtd_caminhao' com 0.\n",
            "Preenchidos 38242 valores NaN na coluna 'qtd_gravidade_fatal' com 0.\n",
            "Preenchidos 37025 valores NaN na coluna 'qtd_gravidade_grave' com 0.\n",
            "Preenchidos 20782 valores NaN na coluna 'qtd_gravidade_leve' com 0.\n",
            "Preenchidos 38783 valores NaN na coluna 'qtd_gravidade_nao_disponivel' com 0.\n",
            "Preenchidos 39461 valores NaN na coluna 'qtd_veic_outros_não_dispo' com 0.\n",
            "Total de 376893 valores NaN preenchidos com 0 nas colunas 'qtd_'.\n"
          ]
        }
      ]

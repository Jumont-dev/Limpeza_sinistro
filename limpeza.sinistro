        "id": "8df71148",
        "outputId": "3d7c9aa1-c7a7-481f-a613-474c56f27f17"
      },
      "source": [
        "qtd_cols = [col for col in df.columns if col.startswith('qtd_')]\n",
        "\n",
        "filled_count = 0\n",
        "for col in qtd_cols:\n",
        "    if df[col].isnull().any():\n",
        "        initial_nulls = df[col].isnull().sum()\n",
        "        df[col] = df[col].fillna(0)\n",
        "        filled_count += initial_nulls\n",
        "        print(f\"Preenchidos {initial_nulls} valores NaN na coluna '{col}' com 0.\")\n",
        "\n",
        "if filled_count == 0:\n",
        "    print(\"Não há valores NaN nas colunas 'qtd_' para preencher com 0.\")\n",
        "else:\n",
        "    print(f\"Total de {filled_count} valores NaN preenchidos com 0 nas colunas 'qtd_'.\")\n"
      ],
      "execution_count": 7,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Preenchidos 181413 valores NaN na coluna 'qtd_pedestre' com 0.\n",
            "Preenchidos 186557 valores NaN na coluna 'qtd_bicicleta' com 0.\n",
            "Preenchidos 121508 valores NaN na coluna 'qtd_motocicleta' com 0.\n",
            "Preenchidos 122013 valores NaN na coluna 'qtd_automovel' com 0.\n",
            "Preenchidos 185908 valores NaN na coluna 'qtd_onibus' com 0.\n",
            "Preenchidos 183764 valores NaN na coluna 'qtd_caminhao' com 0.\n",
            "Preenchidos 184463 valores NaN na coluna 'qtd_gravidade_fatal' com 0.\n",
            "Preenchidos 179576 valores NaN na coluna 'qtd_gravidade_grave' com 0.\n",
            "Preenchidos 106226 valores NaN na coluna 'qtd_gravidade_leve' com 0.\n",
            "Preenchidos 186529 valores NaN na coluna 'qtd_gravidade_nao_disponivel' com 0.\n",
            "Preenchidos 190115 valores NaN na coluna 'qtd_veic_outros_não_dispo' com 0.\n",
            "Total de 1828072 valores NaN preenchidos com 0 nas colunas 'qtd_'.\n"
          ]
        }
      ]
    },

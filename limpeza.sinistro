    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "8a4354c2",
        "outputId": "2ce1bb47-1603-4bfc-e985-8c442d612848"
      },
      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "import datetime\n",
        "\n",
        "# Recarregar o DataFrame original\n",
        "df = pd.read_excel(\"SINISTRO 2026.xlsx\")\n",
        "print(\"DataFrame recarregado do arquivo SINISTRO 2026.xlsx.\")\n",
        "\n",
        "# 2. Redefinir e aplicar a função remover_colunas\n",
        "def remover_colunas(df):\n",
        "  coluna_remover = [\"ano_sinistro\", \"mes_sinistro\", \"dia_sinistro\", \"ano_mes_sinistro\", \"dia_da_semana\", \"turno\", \"tipo_local\", \"cod_ibge\", \"regiao_administrativa\", \"administracao\", \"conservacao\", \"circunscricao\", \"qtd_gravidade_ileso\", \"tp_sinistro_atropelamento\", \"tp_sinistro_colisao_frontal\", \"tp_sinistro_colisao_traseira\", \"tp_sinistro_colisao_lateral\", \"tp_sinistro_colisao_transversal\", \"tp_sinistro_colisao_outros\", \"tp_sinistro_choque\", \"tp_sinistro_capotamento\", \"tp_sinistro_engavetamento\", \"tp_sinistro_tombamento\", \"tp_sinistro_outros\", \"tp_sinistro_nao_disponivel\"]\n",
        "  df = df.drop(columns=coluna_remover, errors='ignore')\n",
        "  return df\n",
        "\n",
        "df = remover_colunas(df)\n",
        "print(\"Colunas removidas com sucesso.\")\n",
        "\n",
        "# 3. Reaplicar a agregação de colunas\n",
        "if 'qtd_veic_outros' in df.columns and 'qtd_veic_nao_disponivel' in df.columns:\n",
        "    df['qtd_veic_outros_não_dispo'] = df['qtd_veic_outros'] + df['qtd_veic_nao_disponivel']\n",
        "    df = df.drop(columns=['qtd_veic_outros', 'qtd_veic_nao_disponivel'])\n",
        "    print(\"Colunas 'qtd_veic_outros' e 'qtd_veic_nao_disponivel' somadas em 'qtd_veic_outros_não_dispo' e removidas.\")\n",
        "else:\n",
        "    print(\"Uma ou ambas as colunas ('qtd_veic_outros', 'qtd_veic_nao_disponivel') não foram encontradas para agregação.\")\n",
        "\n",
        "# 4. Reaplicar tratamento de valores numéricos implausíveis\n",
        "# Tratar valores negativos em 'numero_logradouro'\n",
        "if 'numero_logradouro' in df.columns:\n",
        "    original_negative_count = (df['numero_logradouro'] < 0).sum()\n",
        "    df.loc[df['numero_logradouro'] < 0, 'numero_logradouro'] = np.nan\n",
        "    if original_negative_count > 0:\n",
        "        print(f\"Convertidos {original_negative_count} valores negativos em 'numero_logradouro' para NaN.\")\n",
        "    else:\n",
        "        print(\"Não foram encontrados valores negativos em 'numero_logradouro'.\")\n",
        "\n",
        "# Tratar 0.0 em 'latitude' e 'longitude'\n",
        "for col in ['latitude', 'longitude']:\n",
        "    if col in df.columns:\n",
        "        original_zero_count = (df[col] == 0.0).sum()\n",
        "        df.loc[df[col] == 0.0, col] = np.nan\n",
        "        if original_zero_count > 0:\n",
        "            print(f\"Convertidos {original_zero_count} valores 0.0 em '{col}' para NaN.\")\n",
        "        else:\n",
        "            print(f\"Não foram encontrados valores 0.0 em '{col}'.\")\n",
        "\n",
        "print(\"Valores numéricos implausíveis tratados (negativos e 0.0).\")\n"
      ],
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "DataFrame recarregado do arquivo SINISTRO 2026.xlsx.\n",
            "Colunas removidas com sucesso.\n",
            "Colunas 'qtd_veic_outros' e 'qtd_veic_nao_disponivel' somadas em 'qtd_veic_outros_não_dispo' e removidas.\n",
            "Convertidos 2 valores negativos em 'numero_logradouro' para NaN.\n",
            "Convertidos 6627 valores 0.0 em 'latitude' para NaN.\n",
            "Convertidos 6627 valores 0.0 em 'longitude' para NaN.\n",
            "Valores numéricos implausíveis tratados (negativos e 0.0).\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 479
        },
        "id": "b56e44b6",
        "outputId": "c5b5d64c-d9dc-4f0b-94c6-8666e5b3c10e"
      },
      "source": [
        "if 'hora_sinistro' in df.columns:\n",
        "    def convert_to_time_robust(value):\n",
        "        if pd.isna(value):\n",
        "            return pd.NaT\n",
        "        if isinstance(value, datetime.time):\n",
        "            return value\n",
        "        try:\n",
        "\n",
        "            return pd.to_datetime(str(value)).time()\n",
        "        except:\n",
        "\n",
        "            return pd.NaT\n",
        "\n",
        "    original_nan_count_hs = df['hora_sinistro'].isnull().sum()\n",
        "    df['hora_sinistro'] = df['hora_sinistro'].apply(convert_to_time_robust)\n",
        "    new_nan_count_hs = df['hora_sinistro'].isnull().sum()\n",
        "\n",
        "    print(f\"Coluna 'hora_sinistro' convertida para o tipo de tempo. NaNs originais: {original_nan_count_hs}, NaNs após conversão: {new_nan_count_hs}.\")\n",
        "    display(df[['hora_sinistro']].head())\n",
        "    display(df['hora_sinistro'].value_counts(dropna=False).head())\n",
        "else:\n",
        "    print(\"Coluna 'hora_sinistro' não encontrada para conversão.\")"
      ],
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Coluna 'hora_sinistro' convertida para o tipo de tempo. NaNs originais: 40, NaNs após conversão: 40.\n"
